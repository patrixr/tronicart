{
  "name": "@tronicart/cc",
  "version": "1.0.1",
  "description": "P5 reusable goodies",
  "main": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "scripts": {
    "build": "pnpm run build:esm && pnpm run build:amd",
    "build:esm": "tsc --module esnext --outDir dist/esm",
    "build:amd": "tsc --module amd --outFile dist/cc.amd.js",
    "test": "ava"
  },
  "exports": {
    "./*": "./dist/esm/*"
  },
  "keywords": [
    "p5",
    "typescript",
    "lib",
    "canvas"
  ],
  "author": "Patrick",
  "license": "ISC",
  "dependencies": {
    "color-scheme": "^1.0.1",
    "canvas-capture": "^2.1.1"
  },
  "peerDependencies": {
    "p5": "^1.6.0"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "require": [
      "ts-node/register"
    ]
  }
}
