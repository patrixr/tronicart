package objects

import (
	. "raytracer/internal/geometry"
	"raytracer/internal/utils"

	"github.com/mitchellh/mapstructure"
)


func (world *World) Intersect(ray Ray, limit utils.Range) (bool, Intersection) {
	hitAnything := false
	closestSoFar := 100000000.0
	intersection := Intersection{}

	for _, shape := range world.Shapes {
		hit, tempIntersection := shape.Intersect(ray, limit)

		if hit && tempIntersection.Dist < closestSoFar {
			hitAnything = true
			closestSoFar = tempIntersection.Dist
			intersection = tempIntersection
		}
	}

	return hitAnything, intersection
}

// Deserialize the world from a YAML file
// --------------------------------------------

func (s *World) UnmarshalYAML(unmarshal func(interface{}) error) error {
	shapes := make([]map[string]interface{}, 0, 50)

	utils.PanicOnError(unmarshal(&shapes))

	for _, shape := range shapes {
		s.Shapes = append(s.Shapes, DecodeShape(shape))
	}

	return nil
}

func DecodeShape(data map[string]interface{}) Shape {
	shapeType := data["type"]

	if shapeType == "sphere" {
		sphere := Sphere{}
		utils.PanicOnError(
			mapstructure.Decode(data, &sphere),
		)
		return &sphere
	}

	utils.Log.Fatal("Unknown shape type ", shapeType)
	return nil
}
