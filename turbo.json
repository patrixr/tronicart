{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build", "test"],
      "outputs": ["./dist/**"]
    },
    "release": {
      "dependsOn": ["^build", "test"],
      "outputs": ["./dist/**", "./dist-zip/**"]
    },
    "serve": {
      "dependsOn": ["^build"],
      "persistent": true
    },
    "test": {
      "dependsOn": []
    }
  }
}
