{
  "include": ["**/*.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist/**/*"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "jsx": "preserve",
    "esModuleInterop": true,
    "sourceMap": true,
    "allowJs": true,
    "lib": ["es6", "dom"],
    "moduleResolution": "node",
    "baseUrl": "./",
    "rootDir": "."
  },
  "ts-node": {
    // these options are overrides used only by ts-node
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
